---
interface Props {
  title?: string;
  description?: string;
}
const { title = 'Matthias Zoettl | Portfolio', description = 'Photographer & Filmmaker based in Vienna.' } = Astro.props;
// Absolute URL for social-share previews (requires `site` in astro.config.mjs).
const ogImage = new URL('/images/postcards/postcard-01.jpg', Astro.site).href;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" sizes="32x32" href="/images/ui/favicons/favicon-32x32.png" />
    <meta name="theme-color" content="#141414" />

    <!-- Open Graph / Twitter — social share previews.
         TIP: for absolute image URLs, set `site` in astro.config.mjs. -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={Astro.site} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Apply saved theme + mark intro state before paint to avoid flash -->
    <script is:inline>
      (function () {
        try {
          if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
        // Play the full intro only once per browser session. On later loads
        // (e.g. a reload while scrolled down) skip it pre-paint so there's no
        // flash of the loader and the scroll position is preserved.
        var introSeen = false;
        try { introSeen = !!sessionStorage.getItem('introPlayed'); } catch (e) {}
        // Like the reference (oakâme): the intro is a desktop-only flourish —
        // skip it on narrow screens / mobile (< 1200px) and just show the page.
        var smallScreen = window.innerWidth < 1200;
        document.documentElement.classList.add((introSeen || smallScreen) ? 'intro-done' : 'is-intro');
      })();
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=Manrope:wght@200;300;400;500;600;700;800&family=Montserrat:wght@300;400;500;800&display=swap" rel="stylesheet" />

    <!-- Fancybox CSS — non-render-blocking (only needed once a lightbox opens) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.css" media="print" onload="this.media='all'" />

    <!-- GSAP — deferred so it doesn't block first paint; the init below waits
         for DOMContentLoaded, by which point deferred scripts have run. -->
    <script defer src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js" is:inline></script>
  </head>
  <body>

    <!-- Loader -->
    <div id="loader">
      <div class="loader-bg"></div>
      <div class="loader-title">
        <span class="loader-title-left">matthias</span>
        <span class="loader-title-right">zoettl</span>
      </div>
      <div class="loader-counter">
        <span id="loader-count">0</span><span class="loader-counter-sym">%</span>
      </div>
    </div>

    <!-- Page -->
    <div id="page" style="opacity:0">
      <slot />
    </div>

    <!-- Fancybox JS — deferred (only needed for the lightbox) -->
    <script defer src="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.umd.js" is:inline></script>

    <script is:inline>
      // Run after DOMContentLoaded so the deferred GSAP/Fancybox have loaded.
      document.addEventListener('DOMContentLoaded', function () {
        const loader      = document.getElementById('loader');
        const page        = document.getElementById('page');
        const countEl     = document.getElementById('loader-count');
        const titleLeft   = document.querySelector('.loader-title-left');
        const titleRight  = document.querySelector('.loader-title-right');
        const counterWrap = document.querySelector('.loader-counter');
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // No GSAP at all — show the page and stop (nothing animated can run).
        if (typeof gsap === 'undefined') {
          loader.style.display = 'none';
          document.documentElement.classList.remove('is-intro');
          page.style.opacity = '1';
          return;
        }

        // Reduced-motion users: pause the autoplaying hero video. (The intro and
        // the looping logo/tagline animations are skipped further below.)
        if (reduceMotion) {
          const hv = document.querySelector('.hero-video');
          if (hv) { try { hv.removeAttribute('autoplay'); hv.pause(); } catch (e) {} }
        }

        // Play the one-time intro only on the first load of the session.
        // EITHER WAY, the page-wide animations further down (logo flip, tagline
        // cycling, gallery fade-in, scroll reveals, dark toggle) still run —
        // ONLY this intro block is gated. Skip on small screens too (desktop-
        // only intro, like the reference) so the loader never shows on mobile.
        if (document.documentElement.classList.contains('intro-done') || reduceMotion || window.innerWidth < 1200) {
          // Already played / reduced-motion / mobile: show the page, keep scroll.
          loader.style.display = 'none';
          document.documentElement.classList.remove('is-intro');
          page.style.opacity = '1';
          if ('scrollRestoration' in history) history.scrollRestoration = 'auto';
        } else {
          // Intro plays — remember it for the session and start at the top.
          try { sessionStorage.setItem('introPlayed', '1'); } catch (e) {}
          if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
          window.scrollTo(0, 0);

          // Hero text hidden until the hero has grown to full size
          gsap.set(['.hero-left', '.hero-right'], { y: 40, opacity: 0 });
        // Name halves fade up at center, then split out to the borders
        gsap.set([titleLeft, titleRight], { opacity: 0, yPercent: 40 });
        gsap.set(counterWrap, { opacity: 0 });
        // Page is painted behind the loader's solid bg layer the whole time,
        // so the small hero is ready to be uncovered.
        gsap.set(page, { opacity: 1 });

        const rem = parseFloat(getComputedStyle(document.documentElement).fontSize) || 16;
        const EASE = 'power2.inOut'; // one smooth glide shared across the intro
        const SMALL = 0.32;          // scale of the small-window stage

        // Hero geometry — layout size is unaffected by the scale transform.
        const heropage = document.querySelector('.heropage');
        const heroW = heropage.offsetWidth;
        const heroH = heropage.offsetHeight;
        const cX = window.innerWidth / 2;
        const cY = heropage.offsetTop + heroH / 2; // the video's centre line
        const HERO_RADIUS = 0.4 * rem;             // matches the resting 0.4em corners

        const grow = { s: 0 };
        // Each frame: scale the hero (keeping rounding constant) AND punch a
        // hole in the loader matching the video's footprint. The white + words
        // outside the hole are clipped away, so as the video grows it eats the
        // text — the words disappear BEHIND the video instead of fading.
        // (This stays entirely inside the loader, so #page / the nav are never
        // touched.)
        const applyGrow = () => {
          const s = grow.s;
          const r = s > 0.0001 ? Math.min(HERO_RADIUS / s, 260) : 260;
          gsap.set('.heropage', { scale: s, borderRadius: r + 'px' });
          if (s < 0.001) { loader.style.clipPath = 'none'; return; }
          const hw = (heroW * s) / 2, hh = (heroH * s) / 2;
          const L = cX - hw, R = cX + hw, T = cY - hh, B = cY + hh;
          loader.style.clipPath =
            'polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%, 0% 0%, ' +
            L + 'px ' + T + 'px, ' + L + 'px ' + B + 'px, ' +
            R + 'px ' + B + 'px, ' + R + 'px ' + T + 'px, ' + L + 'px ' + T + 'px)';
        };
        applyGrow(); // pin hero at scale 0 before it's uncovered
        document.documentElement.classList.remove('is-intro');

        // Centre the words on the video's centre line.
        gsap.set('.loader-title', { top: cY });

        // The words only move far enough to clear the small video (+ a gap),
        // NOT all the way to the viewport edges.
        const halfVid   = (heroW * SMALL) / 2;
        const sideGap   = rem * 1.5;
        const leftEdge  = cX - halfVid - sideGap; // matthias' right edge lands here
        const rightEdge = cX + halfVid + sideGap; // zoettl's left edge lands here

        const counter = { val: 0 };
        const tl = gsap.timeline();

        // Name fades up at center
        tl.to([titleLeft, titleRight], {
          opacity: 1, yPercent: 0, duration: 0.65, ease: 'power3.out', stagger: 0.05,
        }, 0);

        // Counter fades in + counts — decorative, does NOT gate the reveal
        tl.to(counterWrap, { opacity: 1, duration: 0.3, ease: 'power2.out' }, 0.15)
          .to(counter, {
            val: 100, duration: 1.2, ease: 'power1.inOut',
            onUpdate: () => { countEl.textContent = Math.round(counter.val); },
          }, 0.2);

        // Split the words apart just enough to open a gap for the small video.
        tl.to(titleLeft, {
          x: () => leftEdge - titleLeft.getBoundingClientRect().right,
          duration: 0.9, ease: EASE,
        }, 0.45)
          .to(titleRight, {
            x: () => rightEdge - titleRight.getBoundingClientRect().left,
            duration: 0.9, ease: EASE,
          }, '<');

        // Phase 1: hero grows 0 -> small. The clip-hole opens with it, so the
        // small video appears in the gap between the words.
        tl.to(grow, { s: SMALL, duration: 0.7, ease: 'power2.out', onUpdate: applyGrow }, 0.85);

        // Phase 2: hero grows small -> full. The hole grows too, so the video
        // slides OVER the words — they disappear behind it (no fade).
        tl.to(grow, { s: 1, duration: 1.15, ease: EASE, onUpdate: applyGrow }, 1.9);

        // Fade the thin leftover margin of the loader, then drop it.
        tl.to(loader, { opacity: 0, duration: 0.3, ease: 'power1.out' }, '>-0.1')
          .set(loader, { display: 'none' });

        // Rise the hero text in after the hero has settled at full size.
        tl.to('.hero-left', {
          y: 0, opacity: 1, duration: 0.8, ease: 'power3.out',
        }, '>-0.05');
        } // end one-time intro — everything below runs on every load

        // Fancybox — bind all groups
        if (typeof Fancybox !== 'undefined') {
          Fancybox.bind('[data-fancybox]', {
            Toolbar: {
              display: { left: [], middle: [], right: ['close'] },
            },
            showClass: 'f-fadeIn',
            hideClass: 'f-fadeOut',
            dragToClose: false,
            Images: { zoom: false, Panzoom: { panMode: 'mousemove' } },
            Carousel: {
              transition: 'fade',
              infinite: true,
            },
          });
        }

        // Fade-in gallery images on scroll
        const imgs = document.querySelectorAll('.gallery__img');
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('fadeIn'); io.unobserve(e.target); } });
        }, { threshold: 0.1 });
        imgs.forEach((img) => io.observe(img));

        // Dark mode toggle
        const btn = document.getElementById('theme-toggle');
        const html = document.documentElement;

        function updateToggle(isDark) {
          const label = document.getElementById('toggle-label');
          if (label) label.textContent = isDark ? 'Light' : 'Dark';
        }

        updateToggle(html.classList.contains('dark'));

        btn?.addEventListener('click', () => {
          const isDark = html.classList.toggle('dark');
          try { localStorage.setItem('theme', isDark ? 'dark' : 'light'); } catch (e) {}
          updateToggle(isDark);
        });

        // Tagline cycling image — appears on scroll, then starts cycling.
        // Pulls a random subset straight from the grid (stays in sync), and
        // PRELOADS them so the fast 180ms crossfade never lands on an
        // un-downloaded image (which would flash white).
        const taglineImgs = Array.from(document.querySelectorAll('#view-grid .gallery__img'))
          .map((el) => el.getAttribute('src'))
          .filter(Boolean)
          .sort(() => Math.random() - 0.5)
          .slice(0, 12);
        taglineImgs.forEach((src) => { const im = new Image(); im.src = src; });

        const thumbWrap = document.querySelector('.tagline-thumb-wrap');
        const tA = document.querySelector('.t-img-a');
        const tB = document.querySelector('.t-img-b');

        if (thumbWrap && tA && tB && taglineImgs.length) {
          let idx = 0;
          let useA = true;
          tA.style.backgroundImage = `url('${taglineImgs[0]}')`;

          function startCycling() {
            setInterval(() => {
              idx = (idx + 1) % taglineImgs.length;
              if (useA) {
                tB.style.backgroundImage = `url('${taglineImgs[idx]}')`;
                tB.style.opacity = '1';
                tA.style.opacity = '0';
              } else {
                tA.style.backgroundImage = `url('${taglineImgs[idx]}')`;
                tA.style.opacity = '1';
                tB.style.opacity = '0';
              }
              useA = !useA;
            }, 180);
          }

          const thumbObs = new IntersectionObserver((entries) => {
            entries.forEach(e => {
              if (e.isIntersecting) {
                // Small delay so user sees the text first
                setTimeout(() => {
                  thumbWrap.classList.add('visible');
                  if (!reduceMotion) setTimeout(startCycling, 900);
                }, 300);
                thumbObs.unobserve(thumbWrap);
              }
            });
          }, { threshold: 0.8 });

          thumbObs.observe(thumbWrap);
        }

        // Trusted-by rotating logos (cube flip) — 5 persistent faces, no DOM mutation per tick
        const faces = Array.from(document.querySelectorAll('.logo-flip-face'));
        if (faces.length > 1) {
          let activeIdx = 0;
          gsap.set(faces, { rotationX: 90, transformOrigin: '50% 50% -11px', force3D: true });
          gsap.set(faces[0], { rotationX: 0 });

          function flipNext() {
            const fromIdx = activeIdx;
            const toIdx = (activeIdx + 1) % faces.length;
            // Park every other face out of view so a delayed/queued tween can't leak
            faces.forEach((f, i) => {
              if (i !== fromIdx && i !== toIdx) gsap.set(f, { rotationX: 90 });
            });
            gsap.set(faces[toIdx], { rotationX: 90 });
            const tl = gsap.timeline({
              defaults: { duration: 0.7, ease: 'sine.inOut', force3D: true },
            });
            tl.to(faces[fromIdx], { rotationX: -90 }, 0);
            tl.to(faces[toIdx],   { rotationX: 0   }, 0);
            activeIdx = toIdx;
          }
          if (!reduceMotion) setInterval(flipNext, 2400);
        }

        // Scroll reveal animations
        const reveals = document.querySelectorAll('.reveal');
        const revealObs = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) { e.target.classList.add('visible'); revealObs.unobserve(e.target); }
          });
        }, { threshold: 0.15 });
        reveals.forEach((el) => revealObs.observe(el));
      });
    </script>

    <style is:global>
      /* ─── Reduced motion: neutralise transitions/animations + reveal content ─── */
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.001ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.001ms !important;
          scroll-behavior: auto !important;
        }
        .reveal { opacity: 1 !important; transform: none !important; }
        .gallery__img { opacity: 1 !important; }
        #page { opacity: 1 !important; }
      }

      /* ─── Theme variables ─── */
      :root {
        --bg:             #ffffff;
        --sidebar-bg:     #ffffff;
        --text:           rgb(22,22,22);
        --text-muted:     rgba(22,22,22,0.5);
        --text-faint:     rgba(22,22,22,0.3);
        --nav-hover-bg:   rgba(22,22,22,0.05);
        --nav-active-bg:  rgba(22,22,22,0.07);
        --nav-color:      rgba(22,22,22,0.45);
        --nav-hover:      rgba(22,22,22,0.9);
        --nav-active:     rgba(22,22,22,1);
        --logo-h1:        rgba(26,26,26,1);
        --logo-p:         rgba(26,26,26,0.5);
        --shadow:         rgba(22,22,22,0.08);
        --border:         rgba(22,22,22,0.1);
        --scrollbar:      #ddd;
        --section-bg:     #ffffff;
        --sub-vid-color:  rgba(22,22,22,0.9);
        --contact-card-bg:#ffffff;
        --contact-card-hover: rgba(22,22,22,0.02);
        --fancybox-bg:    rgba(255,255,255,0.97);
        --lb-bg:          #f4f3ef;
        --lb-color:       rgba(22,22,22,0.55);
        --lb-color-strong:rgba(22,22,22,0.95);
        --lb-color-faint: rgba(22,22,22,0.35);
        --lb-border:      rgba(22,22,22,0.18);
        --loader-bg:      #ffffff;
        --loader-color:   rgba(17,17,17,0.7);
      }

      html.dark {
        --bg:             #141414;
        --sidebar-bg:     #111111;
        --text:           rgb(225,222,216);
        --text-muted:     rgba(225,222,216,0.5);
        --text-faint:     rgba(225,222,216,0.25);
        --nav-hover-bg:   rgba(255,255,255,0.06);
        --nav-active-bg:  rgba(255,255,255,0.1);
        --nav-color:      rgba(225,222,216,0.4);
        --nav-hover:      rgba(225,222,216,0.9);
        --nav-active:     rgba(225,222,216,1);
        --logo-h1:        rgba(225,222,216,1);
        --logo-p:         rgba(225,222,216,0.45);
        --shadow:         rgba(0,0,0,0.4);
        --border:         rgba(225,222,216,0.1);
        --scrollbar:      #333;
        --section-bg:     #141414;
        --sub-vid-color:  rgba(225,222,216,0.9);
        --contact-card-bg:#1a1a1a;
        --contact-card-hover: rgba(255,255,255,0.03);
        --fancybox-bg:    rgba(20,20,20,0.97);
        --lb-bg:          #0f0f0f;
        --lb-color:       rgba(230,228,222,0.55);
        --lb-color-strong:rgba(230,228,222,0.95);
        --lb-color-faint: rgba(230,228,222,0.35);
        --lb-border:      rgba(230,228,222,0.18);
        --loader-bg:      #141414;
        --loader-color:   rgba(225,222,216,0.7);
      }

      /* ─── Base ─── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      [hidden] { display: none !important; }
      html { scroll-behavior: smooth; scroll-snap-type: y proximity; }

      body {
        background: var(--bg);
        font-family: 'Montserrat', sans-serif;
        font-size: 19pt;
        font-weight: 300;
        line-height: 1.5em;
        color: var(--text);
        transition: background 0.3s ease, color 0.3s ease;
      }

      h2 {
        font-family: 'Cormorant Garamond', serif;
        font-weight: 300;
        font-size: 1.5em;
        letter-spacing: -1px;
        line-height: 1.5em;
        color: var(--text);
      }

      a { text-decoration: none; color: inherit; }

      /* ─── Loader ─── */
      #loader {
        position: fixed; inset: 0; z-index: 999;
        color: var(--loader-color);
        overflow: hidden;
      }
      /* Solid background layer — fades away to uncover the small hero. */
      .loader-bg {
        position: absolute; inset: 0;
        background: var(--loader-bg);
        z-index: 0;
        transition: background 0.3s ease;
      }
      /* Intro already played this session — no loader, page shown immediately. */
      html.intro-done #loader { display: none; }
      html.intro-done #page { opacity: 1 !important; }
      /* Split name, centered. The two halves slide apart to reveal the hero. */
      .loader-title {
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        z-index: 1;
        display: flex;
        align-items: baseline;
        gap: 0.28em;
        white-space: nowrap;
        font-family: 'Manrope', sans-serif;
        font-weight: 700;
        font-size: clamp(28px, 5.2vw, 66px);
        letter-spacing: -0.04em;
        text-transform: lowercase;
        line-height: 1;
        color: var(--text, #111);
      }
      /* Hidden until GSAP fades them in (GSAP is deferred, so this avoids a
         flash of the static words before the intro starts). */
      .loader-title-left,
      .loader-title-right { display: inline-block; will-change: transform; opacity: 0; }
      .loader-counter {
        position: absolute;
        z-index: 1;
        bottom: 7%; left: 0; right: 0;
        text-align: center;
        font-family: 'Manrope', sans-serif;
        font-weight: 600;
        font-size: clamp(13px, 1.3vw, 18px);
        letter-spacing: 0.14em;
        color: var(--loader-color);
        font-variant-numeric: tabular-nums;
        opacity: 0; /* GSAP fades it in (deferred-load flash guard) */
      }
      .loader-counter-sym { margin-left: 0.15em; opacity: 0.6; }

      /* ─── Top Nav ─── */
      #topnav {
        position: fixed; top: 0; left: 0; right: 0;
        z-index: 100;
        display: flex; align-items: center; justify-content: space-between;
        padding: 1em 2em;
        mix-blend-mode: difference;
      }
      .topnav-name {
        font-family: 'Manrope', sans-serif;
        font-size: 0.38em; font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: lowercase;
        color: #ffffff;
      }
      .topnav-actions {
        display: flex; align-items: center; gap: 1.2em;
      }
      .topnav-contact {
        font-family: 'Manrope', sans-serif;
        font-size: 0.3em; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.2em;
        line-height: 1;
        color: #ffffff;
        border: 1px solid rgba(255,255,255,0.6);
        padding: 0.85em 1.6em;
        border-radius: 999px;
      }

      /* ─── Theme toggle ─── */
      #theme-toggle {
        display: flex; align-items: center; gap: 0.5em;
        background: none; border: none; cursor: pointer;
        font-family: 'Manrope', sans-serif;
        font-size: 0.3em; font-weight: 500;
        text-transform: uppercase; letter-spacing: 0.15em;
        color: #ffffff;
        padding: 0;
      }
      .toggle-track {
        position: relative;
        width: 28px; height: 16px; flex-shrink: 0;
        background: rgba(255,255,255,0.3);
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,0.6);
      }
      .toggle-thumb {
        position: absolute;
        top: 2px; left: 2px;
        width: 10px; height: 10px;
        border-radius: 50%;
        background: #ffffff;
        transition: transform 0.25s ease;
      }
      html.dark .toggle-thumb { transform: translateX(12px); }

      /* ─── Hero ─── */
      .heropage {
        margin: 85px 8px 8px;
        height: calc(100vh - 93px);
        position: relative; border-radius: 0.4em;
        overflow: hidden;
        transform-origin: center center;
        will-change: transform;
        /* Make the hero box a query container so the stage can size itself to
           cover it based on the box's actual aspect ratio. */
        container-type: size;
      }
      /* During the intro the hero starts hidden at scale 0; GSAP grows it
         0 -> small -> full. (Prevents a full-size flash before JS runs.) */
      html.is-intro .heropage {
        transform: scale(0);
      }

      /* ─── Trusted-by bar — sits on the nav row at the top of the page,
            but scrolls away with the page (not fixed like the nav) ─── */
      .trusted-by {
        position: absolute;
        top: 0; left: 50%;
        transform: translateX(-50%);
        z-index: 99;
        display: flex;
        align-items: center;
        gap: 1em;
        padding: 1em 0;
