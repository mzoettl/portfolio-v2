---
import { brands } from '../data/brands';
---

<section id="clients" class="py-20 px-8 lg:px-16">
  <div class="max-w-5xl mx-auto">

    <div class="mb-12">
      <h2 class="font-serif text-4xl font-light text-ink">Clients</h2>
      <p class="text-muted text-sm mt-2 tracking-wide">Brands I've had the pleasure to work with.</p>
    </div>

    <div class="flex flex-wrap items-center gap-8 lg:gap-12">
      {brands.map((brand) => (
        <div class="group">
          <img
            src={brand.logo}
            alt={brand.name}
            class="h-8 object-contain grayscale opacity-50 hover:opacity-90 hover:grayscale-0 transition-all duration-300"
          />
        </div>
      ))}
    </div>

  </div>
</section>
