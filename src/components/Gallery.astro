---

<section id="photography">
  <div class="gallery-toggle">
    <div class="gallery-toggle-track">
      <div class="gallery-toggle-bg"></div>
      <button class="gallery-btn active" id="btn-grid">Grid</button>
      <button class="gallery-btn" id="btn-collections">Collections</button>
    </div>
  </div>

  <!-- ── Grid view ── -->
  <div id="view-grid" class="container-gallery">
    {gridImages.map((img, i) => (
      <figure class={`gallery-item gallery-item${i + 1}`}>
        <a href={img.src} data-fancybox="gallery" data-caption={img.caption}>
          <img src={img.src} class="gallery__img" alt={img.alt} loading="lazy" />
        </a>
      </figure>
    ))}
  </div>

  <!-- ── Collections view ── -->
  <div id="view-collections" class="collections-view" hidden>
    {categories.map((cat, i) => (
      <div class="collection-block">
        <div class="collection-header">
          <div class="collection-meta">
            <h3 class="collection-title">{cat.name}</h3>
          </div>
        </div>
        <div class="collection-strip-wrap">
          <div class="collection-strip">
            {cat.images.map(img => (
              <a
                href={img.src}
                data-fancybox={`col-${i}`}
                data-caption={img.alt}
                class="collection-thumb"
                data-span={img.portrait ? "2" : "1"}
                style={img.customWidth ? `width:${img.customWidth}px` : undefined}
              >
                <img src={img.src} alt={img.alt} loading="lazy" />
              </a>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  const btnGrid = document.getElementById('btn-grid');
  const btnCollections = document.getElementById('btn-collections');
  const viewGrid = document.getElementById('view-grid') as HTMLElement | null;
  const viewCollections = document.getElementById('view-collections') as HTMLElement | null;

  // Sliding active/hover pill (composite.nyc style)
  const toggleTrack = document.querySelector<HTMLElement>('.gallery-toggle-track');
  const toggleBg = document.querySelector<HTMLElement>('.gallery-toggle-bg');
  const toggleBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.gallery-btn'));

  function moveBg(target: HTMLElement) {
    if (!toggleTrack || !toggleBg) return;
    const t = target.getBoundingClientRect();
    const c = toggleTrack.getBoundingClientRect();
    toggleBg.style.width = `${t.width}px`;
    toggleBg.style.transform = `translateX(${t.left - c.left}px)`;
  }
  function moveBgToActive() {
    const active = toggleBtns.find(b => b.classList.contains('active'));
    if (active) moveBg(active);
  }
  if (toggleTrack && toggleBg && toggleBtns.length) {
    requestAnimationFrame(() => {
      moveBgToActive();
      // Defer enabling the transition so the initial position doesn't animate from 0
      setTimeout(() => {
        toggleBg.style.transition = 'width 0.3s ease, transform 0.3s ease';
      }, 50);
    });
    toggleBtns.forEach(btn => {
      btn.addEventListener('mouseenter', () => moveBg(btn));
    });
    toggleTrack.addEventListener('mouseleave', moveBgToActive);
    window.addEventListener('resize', moveBgToActive);
  }

  function fadeSwitch(hideEl: HTMLElement, showEl: HTMLElement) {
    hideEl.style.opacity = '0';
    hideEl.style.transition = 'opacity 0.2s ease';
    setTimeout(() => {
      hideEl.setAttribute('hidden', '');
      hideEl.style.opacity = '';
      hideEl.style.transition = '';
      showEl.removeAttribute('hidden');
      showEl.style.opacity = '0';
      requestAnimationFrame(() => requestAnimationFrame(() => {
        showEl.style.transition = 'opacity 0.35s ease';
        showEl.style.opacity = '1';
        setTimeout(() => { showEl.style.transition = ''; showEl.style.opacity = ''; }, 350);
      }));
    }, 200);
  }

  btnGrid?.addEventListener('click', () => {
    if (btnGrid.classList.contains('active')) return;
    btnGrid.classList.add('active');
    btnCollections?.classList.remove('active');
    moveBgToActive();
    if (viewCollections && viewGrid) fadeSwitch(viewCollections, viewGrid);
  });

  btnCollections?.addEventListener('click', () => {
    if (btnCollections.classList.contains('active')) return;
    btnCollections.classList.add('active');
    btnGrid?.classList.remove('active');
    moveBgToActive();
    if (viewGrid && viewCollections) fadeSwitch(viewGrid, viewCollections);
  });

  // Drag-to-scroll + scroll direction hints on collection strips
  document.querySelectorAll<HTMLElement>('.collection-strip').forEach(strip => {
    const wrap = strip.closest<HTMLElement>('.collection-strip-wrap');
    let isDown = false;
    let startX = 0;
    let scrollLeft = 0;
    let moved = false;

    function updateScrollHints() {
      if (!wrap) return;
      wrap.classList.toggle('can-scroll-left',  strip.scrollLeft > 2);
      wrap.classList.toggle('can-scroll-right', strip.scrollLeft < strip.scrollWidth - strip.clientWidth - 2);
    }

    // Set initial state after layout
    requestAnimationFrame(updateScrollHints);
    strip.addEventListener('scroll', updateScrollHints);

    // Stop the browser from native-dragging images (ghost) while panning.
    strip.querySelectorAll('img, a').forEach(el => el.setAttribute('draggable', 'false'));

    strip.addEventListener('mousedown', (e) => {
      isDown = true;
      moved = false;
      startX = e.pageX;
      scrollLeft = strip.scrollLeft;
      strip.dataset.dragging = ''; // cursor: grabbing
    });
    const endDrag = () => { isDown = false; delete strip.dataset.dragging; };
    strip.addEventListener('mouseleave', endDrag);
    window.addEventListener('mouseup', endDrag);
    strip.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      const dx = e.pageX - startX;
      if (Math.abs(dx) > 4) moved = true;        // only a drag past a small threshold
      if (moved) { e.preventDefault(); strip.scrollLeft = scrollLeft - dx * 1.5; }
    });

    // Suppress the lightbox ONLY if the user actually dragged (not a clean click).
    // `moved` stays true through mouseup→click, and resets on the next mousedown.
    strip.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', (e) => {
        if (moved) { e.preventDefault(); e.stopPropagation(); }
      });
    });
  });

  // "explore →" opens first image in that collection
  document.querySelectorAll<HTMLElement>('.collection-view-all').forEach(el => {
    el.addEventListener('click', () => {
      const colIndex = el.dataset.col;
      const firstThumb = document.querySelector<HTMLAnchorElement>(`[data-fancybox="col-${colIndex}"]`);
      firstThumb?.click();
    });
  });
</script>
