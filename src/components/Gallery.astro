  { src: "/images/do-not-disturb/quiet-08.jpg",         alt: "Quiet moment",              caption: "Do Not Disturb" },
  { src: "/images/do-not-disturb/quiet-12.jpg",         alt: "Quiet figure",              caption: "Do Not Disturb" },
